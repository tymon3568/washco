# Database
DATABASE_URL=postgres://washco:washco@localhost:5432/washco
POSTGRES_PASSWORD=washco
DB_MAX_CONNECTIONS=50
DB_IDLE_TIMEOUT_SECONDS=300
DB_MAX_LIFETIME_SECONDS=1800

# KeyDB
REDIS_URL=redis://localhost:6379

# RustFS (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=washco
S3_ACCESS_KEY=washco
S3_SECRET_KEY=washco-secret
S3_REGION=us-east-1

# JWT - CHANGE IN PRODUCTION!
JWT_SECRET=change-me-in-production
JWT_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_SECONDS=604800

# Server
HOST=0.0.0.0
PORT=8080
RUST_LOG=washco=debug,tower_http=debug

# CORS - comma-separated origins (set * for permissive in dev)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:3001

# SMS (optional - if not set, SMS are logged to console)
# SMS_API_URL=https://your-sms-provider.com/api/send

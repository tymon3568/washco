# Database
DATABASE_URL=postgres://washco:washco@localhost:5432/washco

# KeyDB
REDIS_URL=redis://localhost:6379

# RustFS (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=washco
S3_ACCESS_KEY=washco
S3_SECRET_KEY=washco-secret
S3_REGION=us-east-1

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_SECONDS=604800

# Server
HOST=0.0.0.0
PORT=8080
RUST_LOG=washco=debug,tower_http=debug
